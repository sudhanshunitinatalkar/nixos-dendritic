# ./modules/wyoming.nix
{ pkgs, ... }: {
  configurations.nixos."cosmoslaptop".module = { pkgs, ... }: 
  let
  # Added a half-second sleep to prevent an asyncio socket collision
      greetScript = pkgs.writeShellScript "jarvis-greet" ''
        ${pkgs.coreutils}/bin/sleep 0.5
        
        # We put the log back to prove execution happens
        echo "--- Executing dynamic TTS at $(date) ---" >> /tmp/jarvis_debug.log
        
        echo '{"type": "synthesize", "data": {"text": "Yes?"}}' | \
        ${pkgs.socat}/bin/socat - TCP:127.0.0.1:10200 | \
        ${pkgs.socat}/bin/socat - TCP:127.0.0.1:10700 2>> /tmp/jarvis_debug.log
      '';
  in
  {
    services.wyoming = {
      openwakeword = {
        enable = true;
        uri = "tcp://127.0.0.1:10400";
        threshold = 0.1;
        # Added --debug to see the internal search paths
        extraArgs = [ 
          "--preload-model" "hey_jarvis" 
          "--debug"
        ]; 
      };
      satellite = {
        enable = true;
        name = "cosmos-ear";
        uri = "tcp://127.0.0.1:10700";
        user = "sudha";
        group = "users";
        microphone.command = "${pkgs.pipewire}/bin/pw-record --rate=16000 --channels=1 --format=s16 --raw -";             
        sound.command = "${pkgs.pipewire}/bin/pw-play --rate=22050 --channels=1 --format=s16 --raw -";              # 2. ENHANCEMENTS (README recommendation)
        microphone.autoGain = 15; 
        microphone.noiseSuppression = 2; 
        vad.enable = false;
        extraArgs = [
          "--wake-uri" "tcp://127.0.0.1:10400"
          "--wake-word-name" "hey_jarvis"
          "--mic-volume-multiplier" "2.0"
          "--detection-command" "${greetScript}"
          "--debug"
        ];
      };
      
      faster-whisper.servers.stt = {
        enable = true;
        uri = "tcp://127.0.0.1:10300";
        model = "tiny.en";
        language = "en";
        device = "cpu";
      };
      
      piper.servers.tts = {
        enable = true;
        uri = "tcp://127.0.0.1:10200";
        voice = "en_US-lessac-medium";
        extraArgs = [ "--debug" ];
      };
    };

    # Systemd Overrides for PipeWire Access
    systemd.services.wyoming-satellite = {
      path = with pkgs; [ socat pipewire alsa-utils coreutils ];
      environment = {
        XDG_RUNTIME_DIR = "/run/user/1000";
        PIPEWIRE_RUNTIME_DIR = "/run/user/1000";
        PULSE_SERVER = "unix:/run/user/1000/pulse/native";
      };
      serviceConfig = {
        # We no longer need to force hardware access because we're using a socket
        PrivateDevices = pkgs.lib.mkForce false; 
        DevicePolicy = pkgs.lib.mkForce "auto"; 
        ProtectHome = pkgs.lib.mkForce "read-only";
        SupplementaryGroups = [ "audio" ];
      };
    };
  };
}