{ inputs, ... }:
{
  # We push the comin deployment service strictly into the server bucket
  configurations.nixos."cosmos_server".module = { pkgs, ... }: {
    
    imports = [
      # You must ensure 'comin' is defined in your flake.nix inputs!
      inputs.comin.nixosModules.comin 
    ];

    services.comin = {
      enable = true;
      remotes = [
        {
          name = "origin";
          # Guessed from your git config and local directory name
          url = "https://github.com/sudhanshunitinatalkar/nixos-dendritic.git";
          branches = [ "main" ]; # Change to "master" if that is your default branch
        }
      ];
    };

    # Comin requires git to be available at the system level to pull updates
    environment.systemPackages = [ pkgs.git ];
  };
}